@model List<UserPhoneApp.Models.Phone>

<h2>Телефоны</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Добавить телефон</a>
</p>

@if (!Model.Any())
{
    <p>Пока нет телефонов.</p>
}
else
{
    <table class="table">
        <thead>
        <tr>
            <th>Номер</th>
            <th>Пользователь</th>
            <th>Действия</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.PhoneNumber</td>
                <td>@(p.User?.Name ?? "-")</td>
                <td>
                    <a asp-action="Delete" asp-route-id="@p.Id">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
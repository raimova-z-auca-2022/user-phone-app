@model UserPhoneApp.Models.Phone

<h2>Добавить телефон</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="PhoneNumber" class="form-label">Номер</label>
        <input asp-for="PhoneNumber" class="form-control"/>
        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="UserId" class="form-label">Пользователь</label>
        <select asp-for="UserId" class="form-select" asp-items="ViewBag.Users">
            <option value="">-- выберите пользователя --</option>
        </select>
        <span asp-validation-for="UserId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Сохранить</button>
    <a asp-action="Index" class="btn btn-secondary">Назад</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
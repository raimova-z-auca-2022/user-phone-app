@model UserPhoneApp.Models.User

<h2>Пользователь</h2>

<dl class="row">
    <dt class="col-sm-3">Имя</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>

    <dt class="col-sm-3">Дата рождения</dt>
    <dd class="col-sm-9">@((Model.DateOfBirth?.ToString("yyyy-MM-dd")) ?? "-")</dd>
</dl>

<hr />

<div class="d-flex justify-content-between align-items-center">
    <h3 class="mb-0">Телефоны</h3>
    <a class="btn btn-primary"
       asp-controller="Phones"
       asp-action="Create"
       asp-route-userId="@Model.Id">
        + Добавить телефон
    </a>
</div>

@if (Model.Phones == null || !Model.Phones.Any())
{
    <p class="mt-3">У этого пользователя пока нет телефонов.</p>
}
else
{
    <table class="table mt-3">
        <thead>
        <tr>
            <th>Номер</th>
            <th style="width: 160px;">Действия</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var p in Model.Phones)
        {
            <tr>
                <td>@p.PhoneNumber</td>
                <td>
                    <a class="link-danger"
                       asp-controller="Phones"
                       asp-action="Delete"
                       asp-route-id="@p.Id">
                        Delete
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

<p class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Назад</a>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
</p>